---
// Este componente utiliza EmailJS para envío real de emails
---

<section id="contact" class="section-container">
  <div class="mx-auto max-w-3xl rounded-2xl border border-white/20 bg-white/95 p-4 shadow-soft sm:p-6 md:rounded-3xl md:p-8 lg:p-10">
    <h2 class="mb-6 text-center text-2xl font-bold tracking-tight text-slate-900 sm:mb-8 sm:text-3xl md:text-4xl">Contact</h2>
    
    <form id="contact-form" class="space-y-4">
      <div>
        <label for="from_name" class="mb-2 block text-sm font-medium text-slate-800">Nombre</label>
        <input
          id="from_name"
          name="from_name"
          type="text"
          placeholder="Tu nombre"
          class="w-full rounded-lg border-2 border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder-slate-500 outline-none transition focus:border-cyan-400 focus:ring-2 focus:ring-cyan-300/30 sm:rounded-xl sm:px-4 sm:py-3"
          required
        />
      </div>
      <div>
        <label for="from_email" class="mb-2 block text-sm font-medium text-slate-800">Email</label>
        <input
          id="from_email"
          name="from_email"
          type="email"
          placeholder="tu@email.com"
          class="w-full rounded-lg border-2 border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder-slate-500 outline-none transition focus:border-cyan-400 focus:ring-2 focus:ring-cyan-300/30 sm:rounded-xl sm:px-4 sm:py-3"
          required
        />
      </div>
      <div>
        <label for="message" class="mb-2 block text-sm font-medium text-slate-800">Mensaje</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          placeholder="Escribe tu mensaje..."
          class="w-full rounded-lg border-2 border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder-slate-500 outline-none transition focus:border-cyan-400 focus:ring-2 focus:ring-cyan-300/30 sm:rounded-xl sm:px-4 sm:py-3 sm:rows-5"
          required
        ></textarea>
      </div>
      <button type="submit" id="submit-btn" class="card-hover w-full rounded-full bg-slate-900 px-6 py-2.5 text-sm font-semibold text-white shadow-soft transition-all sm:w-auto sm:py-3 disabled:opacity-50 disabled:cursor-not-allowed">
        <span id="btn-text">Enviar mensaje</span>
        <span id="btn-loading" class="hidden">
          <svg class="inline w-4 h-4 mr-2 text-white animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="m4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Enviando...
        </span>
      </button>
    </form>
    
    <!-- Mensaje de éxito/error -->
    <div id="form-message" class="mt-4 hidden rounded-lg p-4"></div>
    
    <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm font-medium text-slate-600 sm:mt-8 sm:gap-4">
      <a href="https://github.com/SantiagoSalvay" target="_blank" rel="noreferrer" class="transition hover:text-cyan-700">GitHub</a>
      <a href="https://www.linkedin.com/in/santiago-salvay-568047277/" target="_blank" rel="noreferrer" class="transition hover:text-cyan-700">LinkedIn</a>
      <a href="mailto:js.salvay@gmail.com" class="transition hover:text-cyan-700">Email</a>
    </div>
  </div>
</section>

<!-- EmailJS SDK -->
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

<script is:inline>
  // Configuración de EmailJS
  // IMPORTANTE: Reemplaza estos valores con los tuyos de EmailJS
  const EMAILJS_SERVICE_ID = "service_tu_id";  // Obtén esto de emailjs.com
  const EMAILJS_TEMPLATE_ID = "template_tu_id"; // Obtén esto de emailjs.com  
  const EMAILJS_PUBLIC_KEY = "tu_public_key";   // Obtén esto de emailjs.com

  // Inicializar EmailJS
  (function() {
    emailjs.init({
      publicKey: EMAILJS_PUBLIC_KEY,
    });
  })();

  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnLoading = document.getElementById('btn-loading');
    const formMessage = document.getElementById('form-message');

    form?.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      // Validar que EmailJS esté configurado
      if (EMAILJS_SERVICE_ID === "service_tu_id" || EMAILJS_TEMPLATE_ID === "template_tu_id" || EMAILJS_PUBLIC_KEY === "tu_public_key") {
        showMessage('Para usar el formulario de contacto, debes configurar EmailJS. Mientras tanto, puedes contactarme directamente por email.', 'warning');
        return;
      }
      
      // Deshabilitar botón y mostrar loading
      submitBtn.disabled = true;
      btnText.classList.add('hidden');
      btnLoading.classList.remove('hidden');
      formMessage.classList.add('hidden');

      try {
        // Enviar email usando EmailJS
        const result = await emailjs.sendForm(
          EMAILJS_SERVICE_ID,
          EMAILJS_TEMPLATE_ID,
          form
        );

        console.log('Email enviado exitosamente:', result);
        
        showMessage('¡Mensaje enviado correctamente! Te responderé pronto.', 'success');
        form.reset();
        
      } catch (error) {
        console.error('Error al enviar email:', error);
        showMessage('Error al enviar el mensaje. Por favor, inténtalo más tarde o contáctame directamente por email.', 'error');
      } finally {
        // Restaurar botón
        submitBtn.disabled = false;
        btnText.classList.remove('hidden');
        btnLoading.classList.add('hidden');
      }
    });

    function showMessage(text, type) {
      const className = type === 'success' 
        ? 'mt-4 rounded-lg p-4 bg-green-50 border border-green-200 text-green-800'
        : type === 'warning'
        ? 'mt-4 rounded-lg p-4 bg-yellow-50 border border-yellow-200 text-yellow-800' 
        : 'mt-4 rounded-lg p-4 bg-red-50 border border-red-200 text-red-800';
      
      formMessage.className = className;
      formMessage.textContent = text;
      formMessage.classList.remove('hidden');
    }
  });
</script>