<section id="contact" class="section-container">
  <div class="mx-auto max-w-3xl rounded-3xl border border-white/20 bg-white/95 p-6 shadow-soft md:p-10">
    <h2 class="mb-8 text-center text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Contact</h2>
    <form class="space-y-4">
      <div>
        <label for="name" class="mb-2 block text-sm font-medium text-slate-700">Nombre</label>
        <input
          id="name"
          name="name"
          type="text"
          placeholder="Tu nombre"
          class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-slate-500 focus:ring-2 focus:ring-cyan-300/40"
          required
        />
      </div>
      <div>
        <label for="email" class="mb-2 block text-sm font-medium text-slate-700">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          placeholder="tu@email.com"
          class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-slate-500 focus:ring-2 focus:ring-cyan-300/40"
          required
        />
      </div>
      <div>
        <label for="message" class="mb-2 block text-sm font-medium text-slate-700">Mensaje</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="Escribe tu mensaje..."
          class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-slate-500 focus:ring-2 focus:ring-cyan-300/40"
          required
        ></textarea>
      </div>
      <button type="submit" class="card-hover w-full rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white shadow-soft sm:w-auto">
        Enviar mensaje
      </button>
    </form>
    <div class="mt-8 flex flex-wrap gap-4 text-sm font-medium text-slate-600">
      <a href="https://github.com/" target="_blank" rel="noreferrer" class="transition hover:text-cyan-700">GitHub</a>
      <a href="https://linkedin.com/" target="_blank" rel="noreferrer" class="transition hover:text-cyan-700">LinkedIn</a>
      <a href="mailto:contacto@santiago.dev" class="transition hover:text-cyan-700">Email</a>
    </div>
  </div>
</section>
