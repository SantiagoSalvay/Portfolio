---
const orbitLogos = [
  { name: "React", icon: "https://cdn.simpleicons.org/react/61DAFB" },
  { name: "JavaScript", icon: "https://cdn.simpleicons.org/javascript/F7DF1E" },
  { name: "Node", icon: "https://cdn.simpleicons.org/nodedotjs/5FA04E" },
  { name: "Docker", icon: "https://cdn.simpleicons.org/docker/2496ED" },
  { name: "Astro", icon: "https://cdn.simpleicons.org/astro/FF5D01" },
  { name: "Figma", icon: "https://cdn.simpleicons.org/figma/F24E1E" },
  { name: "TypeScript", icon: "https://cdn.simpleicons.org/typescript/3178C6" },
  { name: "Postman", icon: "https://cdn.simpleicons.org/postman/FF6C37" },
  { name: "MySQL", icon: "https://cdn.simpleicons.org/mysql/4479A1" },
  { name: "Tailwind", icon: "https://cdn.simpleicons.org/tailwindcss/06B6D4" },
  { name: "Express", icon: "https://cdn.simpleicons.org/express/ffffff" },
  { name: "Vue", icon: "https://cdn.simpleicons.org/vuedotjs/4FC08D" },
  { name: "VS Code", icon: "/vscode.svg" },
  { name: "Git", icon: "https://cdn.simpleicons.org/git/F05032" }
];

const outerOrbit = orbitLogos.slice(0, 7);
const innerOrbit = orbitLogos.slice(7);
---

<section id="hero" class="hero-surface min-h-screen flex items-center">
  <div class="section-container">
    <div class="fade-in-up grid items-center gap-12 lg:grid-cols-2">
      <div class="text-center lg:text-left">
        <p class="mb-3 inline-block rounded-full border border-white/20 bg-white/5 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300 sm:mb-4 sm:px-4 sm:py-2">
          Argentinian Fullstack Developer
        </p>
        <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl">Hi, I'm Santiago</h1>
        <p class="mt-4 max-w-xl text-sm leading-relaxed text-slate-300 sm:mt-6 sm:text-base md:text-lg">
          I build web applications with React, Astro, Express and Node.
        </p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3 sm:mt-8 sm:gap-4 lg:justify-start lg:mt-10">
          <a
            href="#projects"
            class="card-hover rounded-full bg-cyan-400 px-4 py-2.5 text-sm font-semibold text-slate-950 shadow-soft sm:px-5 sm:py-3 md:px-6"
          >
            View Projects
          </a>
          <a
            href="#contact"
            class="card-hover rounded-full border border-white/30 px-4 py-2.5 text-sm font-semibold text-white sm:px-5 sm:py-3 md:px-6"
          >
            Contact
          </a>
        </div>
      </div>

      <div class="hero-orbit-wrap">
        <div class="hero-avatar-ring">
          <img src="/profile.png" alt="Santiago's profile photo" class="hero-avatar-img" loading="eager" />
        </div>
        <div class="orbit orbit-lg">
          {
            outerOrbit.map((item, i) => (
              <span class="orbit-item" style={`--i:${i}; --n:${outerOrbit.length};`}>
                <img src={item.icon} alt={`${item.name} logo`} loading="lazy" />
              </span>
            ))
          }
        </div>
        <div class="orbit orbit-sm">
          {
            innerOrbit.map((item, i) => (
              <span class="orbit-item orbit-item-sm" style={`--i:${i}; --n:${innerOrbit.length};`}>
                <img src={item.icon} alt={`${item.name} logo`} loading="lazy" />
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
