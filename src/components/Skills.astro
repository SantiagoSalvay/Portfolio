---
const languages = [
  { name: "HTML", icon: "https://cdn.simpleicons.org/html5/E34F26" },
  { name: "CSS", icon: "https://cdn.simpleicons.org/css/1572B6" },
  { name: "JavaScript", icon: "https://cdn.simpleicons.org/javascript/F7DF1E" },
  { name: "TypeScript", icon: "https://cdn.simpleicons.org/typescript/3178C6" },
  { name: "React", icon: "https://cdn.simpleicons.org/react/61DAFB" },
  { name: "Astro", icon: "https://cdn.simpleicons.org/astro/FF5D01" },
  { name: "Vue", icon: "https://cdn.simpleicons.org/vuedotjs/4FC08D" },
  { name: "Node", icon: "https://cdn.simpleicons.org/nodedotjs/5FA04E" },
  { name: "Express", icon: "https://cdn.simpleicons.org/express/1f2937" },
  { name: "MySQL", icon: "https://cdn.simpleicons.org/mysql/4479A1" },
  { name: "Next", icon: "https://cdn.simpleicons.org/nextdotjs/111827" },
  { name: "Tailwind", icon: "https://cdn.simpleicons.org/tailwindcss/06B6D4" }
];

const loopLanguages = [...languages, ...languages];
---

<section id="skills" class="section-container">
  <h2 class="mb-10 text-center text-3xl font-bold tracking-tight text-white md:text-4xl">Skills</h2>
  <div class="marquee">
    <div class="marquee-track marquee-track-reverse">
      {
        loopLanguages.map((item) => (
          <div class="marquee-item">
            <img src={item.icon} alt={`Icono de ${item.name}`} loading="lazy" />
            <span>{item.name}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
