---
const tools = [
  { name: "Figma", icon: "https://cdn.simpleicons.org/figma/F24E1E" },
  { name: "Terminal", icon: "https://cdn.simpleicons.org/gnubash/4EAA25" },
  { name: "Docker", icon: "https://cdn.simpleicons.org/docker/2496ED" },
  { name: "XAMPP", icon: "https://cdn.simpleicons.org/xampp/FB7A24" },
  { name: "Claude", icon: "https://cdn.simpleicons.org/anthropic/D4A574" },
  { name: "VS Code", icon: "/vscode.svg" },
  { name: "Photoshop", icon: "/photoshop.svg" },
  { name: "Postman", icon: "https://cdn.simpleicons.org/postman/FF6C37" },
  { name: "Git", icon: "https://cdn.simpleicons.org/git/F05032" },
  { name: "Supabase", icon: "https://cdn.simpleicons.org/supabase/3FCF8E" },
  { name: "NPM", icon: "https://cdn.simpleicons.org/npm/CB3837" },
  { name: "PNPM", icon: "https://cdn.simpleicons.org/pnpm/F69220" }
];
---

<section id="tools" class="section-container scroll-animate opacity-0 translate-y-8">
  <h2 class="mb-8 text-center text-2xl font-bold tracking-tight text-white sm:mb-10 sm:text-3xl md:text-4xl">
    Tools
  </h2>
  <div class="tools-carousel">
    <div class="tools-carousel-track">
      {
        [...tools, ...tools, ...tools, ...tools, ...tools].map((item, index) => (
          <div class="tool-icon">
            <img src={item.icon} alt={`${item.name} icon`} loading="lazy" />
          </div>
        ))
      }
    </div>
  </div>
</section>
