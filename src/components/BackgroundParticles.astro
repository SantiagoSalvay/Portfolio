---
// Componente de partículas de fondo sutiles
---

<div class="fixed inset-0 pointer-events-none z-0" aria-hidden="true">
  <div class="absolute inset-0 overflow-hidden">
    <!-- Partículas flotantes -->
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
    <div class="particle particle-4"></div>
    <div class="particle particle-5"></div>
    <div class="particle particle-6"></div>
  </div>
</div>

<style>
  .particle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    opacity: 0.1;
    animation: float 20s infinite linear;
  }

  .particle-1 {
    width: 4px;
    height: 4px;
    background: linear-gradient(45deg, #22d3ee, #6366f1);
    left: 10%;
    animation-delay: 0s;
    animation-duration: 25s;
  }

  .particle-2 {
    width: 6px;
    height: 6px;
    background: linear-gradient(45deg, #8b5cf6, #ec4899);
    left: 20%;
    animation-delay: -5s;
    animation-duration: 30s;
  }

  .particle-3 {
    width: 3px;
    height: 3px;
    background: linear-gradient(45deg, #10b981, #22d3ee);
    left: 60%;
    animation-delay: -10s;
    animation-duration: 28s;
  }

  .particle-4 {
    width: 5px;
    height: 5px;
    background: linear-gradient(45deg, #f59e0b, #8b5cf6);
    left: 80%;
    animation-delay: -15s;
    animation-duration: 22s;
  }

  .particle-5 {
    width: 4px;
    height: 4px;
    background: linear-gradient(45deg, #6366f1, #10b981);
    left: 40%;
    animation-delay: -8s;
    animation-duration: 26s;
  }

  .particle-6 {
    width: 7px;
    height: 7px;
    background: linear-gradient(45deg, #22d3ee, #f59e0b);
    left: 90%;
    animation-delay: -12s;
    animation-duration: 32s;
  }

  @keyframes float {
    0% {
      transform: translateY(100vh) translateX(-50px) rotate(0deg);
      opacity: 0;
    }
    10% {
      opacity: 0.1;
    }
    90% {
      opacity: 0.1;
    }
    100% {
      transform: translateY(-100px) translateX(50px) rotate(360deg);
      opacity: 0;
    }
  }

  @media (max-width: 768px) {
    .particle {
      opacity: 0.05;
    }
  }
</style>