---
import ProjectCard from "./ProjectCard.astro";

const projects = [
  {
    image: "/portfolio-screenshot.png",
    name: "Portfolio Website",
    description: "Personal portfolio developed with Astro, CSS and JavaScript.",
    stack: ["Astro", "CSS", "JavaScript"],
    githubUrl: "https://github.com/SantiagoSalvay/Portfolio",
    demoUrl: "https://www.santysalvay.dev/"
  },
  {
    image: "/modavista-screenshot.png",
    name: "ModaVista",
    description: "ModaVista – Full-Stack Fashion E-commerce Platform.",
    stack: ["React", "JavaScript", "Express.js", "PostgreSQL", "HTML", "CSS"],
    githubUrl: "https://github.com/SantiagoSalvay/ModaVista.git",
    demoUrl: "https://confidential-judi-1modavista-f0249404.koyeb.app/"
  },
  {
    image: "/redis-quiz-screenshot.png",
    name: "Redis Quiz",
    description: "Quiz about the Redis database. Multiplayer competition of NoSQL databases with real-time participating groups.",
    stack: ["React", "Vite", "Tailwind"],
    githubUrl: "https://github.com/SantiagoSalvay/RedisQuiz/tree/main",
    demoUrl: "https://redis-challenge-rust.vercel.app/"
  },
  {
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&q=80",
    name: "Coming Soon",
    description: "New project in development. Stay tuned for updates!",
    stack: ["TBD"],
    githubUrl: "#",
    demoUrl: "#",
    comingSoon: true
  }
];
---

<section id="projects" class="section-container scroll-animate opacity-0 translate-y-8">
  <h2 class="mb-6 text-center text-2xl font-bold tracking-tight text-white sm:mb-8 sm:text-3xl md:mb-10 md:text-4xl">Projects</h2>
  <div class="grid gap-4 sm:gap-6 md:grid-cols-2 lg:gap-8 xl:grid-cols-3 items-stretch">
    {
      projects.map((project, index) => (
        <div class={`stagger-animate opacity-0 translate-y-4 stagger-${index + 1} h-full`}>
          <ProjectCard
            image={project.image}
            name={project.name}
            description={project.description}
            stack={project.stack}
            githubUrl={project.githubUrl}
            demoUrl={project.demoUrl}
            comingSoon={project.comingSoon}
          />
        </div>
      ))
    }
  </div>
</section>
