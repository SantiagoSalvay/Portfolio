---
interface Props {
  image: string;
  name: string;
  description: string;
  stack: string[];
  githubUrl: string;
  demoUrl: string;
}

const { image, name, description, stack, githubUrl, demoUrl } = Astro.props;
---

<article class="card-hover overflow-hidden rounded-2xl border border-white/20 bg-white/95 shadow-soft">
  <img src={image} alt={`Imagen del proyecto ${name}`} class="h-48 w-full object-cover" loading="lazy" />
  <div class="space-y-4 p-5">
    <h3 class="text-lg font-bold text-slate-900">{name}</h3>
    <p class="text-sm leading-relaxed text-slate-600">{description}</p>
    <p class="text-sm text-slate-500">
      <span class="font-semibold text-slate-700">Stack:</span> {stack.join(", ")}
    </p>
    <div class="flex flex-wrap gap-3 pt-2">
      <a
        href={githubUrl}
        target="_blank"
        rel="noreferrer"
        class="rounded-full bg-slate-900 px-4 py-2 text-xs font-semibold text-white transition hover:opacity-90"
      >
        GitHub
      </a>
      <a
        href={demoUrl}
        target="_blank"
        rel="noreferrer"
        class="rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-100"
      >
        Demo
      </a>
    </div>
  </div>
</article>
