---
interface Props {
  image: string;
  name: string;
  description: string;
  stack: string[];
  githubUrl: string;
  demoUrl: string;
}

const { image, name, description, stack, githubUrl, demoUrl } = Astro.props;
---

<article class="card-hover overflow-hidden rounded-xl border border-white/20 bg-white/95 shadow-soft sm:rounded-2xl">
  <img src={image} alt={`${name} project image`} class="h-40 w-full object-cover sm:h-44 md:h-48" loading="lazy" />
  <div class="space-y-3 p-4 sm:space-y-4 sm:p-5">
    <h3 class="text-base font-bold text-slate-900 sm:text-lg">{name}</h3>
    <p class="text-sm leading-relaxed text-slate-600">{description}</p>
    <p class="text-xs text-slate-500 sm:text-sm">
      <span class="font-semibold text-slate-700">Stack:</span> {stack.join(", ")}
    </p>
    <div class="flex flex-wrap gap-2 pt-1 sm:gap-3 sm:pt-2">
      <a
        href={githubUrl}
        target="_blank"
        rel="noreferrer"
        class="rounded-full bg-slate-900 px-3 py-1.5 text-xs font-semibold text-white transition hover:opacity-90 sm:px-4 sm:py-2"
      >
        GitHub
      </a>
      <a
        href={demoUrl}
        target="_blank"
        rel="noreferrer"
        class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100 sm:px-4 sm:py-2"
      >
        Demo
      </a>
    </div>
  </div>
</article>
